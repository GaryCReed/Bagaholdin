# Copy this file to .env and fill in your values.

# Required — use a long random string (e.g. openssl rand -hex 32)
JWT_SECRET=change-this-to-a-long-random-string

# Database — omit for SQLite next to the binary
# DATABASE_URL=sqlite3://bagaholdin.db
# DATABASE_URL=postgresql://user:pass@localhost/bagaholdin

# Full path to msfconsole if not on PATH
# MSFCONSOLE_PATH=/usr/bin/msfconsole

# WPScan API token — get yours free at https://wpscan.com/profile
# Without a token WPScan still works but vulnerability data is limited.
WPSCAN_API_TOKEN=

# Production only
# COOKIE_SECURE=true
# ALLOWED_ORIGIN=https://your-domain.example.com
